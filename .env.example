# 环境变量示例文件
# 复制为 .env 并填入实际值

# Minimax AI 服务配置
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_MODEL=MiniMax-M2.7

# 兼容旧配置：未设置 MINIMAX_API_KEY 时会读取 OPENAI_API_KEY
OPENAI_API_KEY=

# 应用环境
FLASK_ENV=development
FLASK_DEBUG=true

# 数据库配置
DATABASE_URL=sqlite:///data/tarot_system.db

# 日志级别
LOG_LEVEL=INFO
